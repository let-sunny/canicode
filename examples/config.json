{
  "excludeNodeTypes": ["SLICE", "STICKY"],
  "excludeNodeNames": ["chatbot", "ad-banner", "prototype", "wip"],
  "gridBase": 4,
  "rules": {
    "no-auto-layout": {
      "score": -15,
      "severity": "blocking"
    },
    "raw-value": {
      "score": -3,
      "severity": "missing-info"
    },
    "default-name": {
      "enabled": false
    },
    "missing-responsive-behavior": {
      "score": -8,
      "severity": "blocking"
    }
  }
}
